---
import { getTranslations } from "../i18n/ui";

const t = getTranslations(Astro.currentLocale).about;

// Callout labels, top to bottom. Leaders alternate sides starting at the left
// (UI) — even index anchors to the sheet's left vertex (x=60), odd to the
// right vertex (x=300). Each leader is an obtuse-angled elbow (diagonal + run).
const caps = [
  { y: 58, layer: t.layers[0] },
  { y: 128, layer: t.layers[1] },
  { y: 198, layer: t.layers[2] },
  { y: 268, layer: t.layers[3] },
  { y: 338, layer: t.layers[4] },
];

// Lay each icon flat on its sheet's isometric top face. The square design space
// maps onto the diamond via this matrix (translate baked into e/f per icon).
const ISO = "1.44 0.576 -1.44 0.576";
---

<!-- Decorative isometric "stacking layers" diagram, annotated like an
     instruction-manual exploded view. Stack top to bottom: UI · API · DATA ·
     AI · CONCEPT. Each solid sheet = top diamond + two front thickness faces;
     AI and CONCEPT are dashed (the non-tangible layers). Each layer carries a
     line glyph laid flat on its face, plus a leader line to a captioned term. -->
<svg class="about-layers" viewBox="-120 0 620 396" fill="none" aria-hidden="true" focusable="false">
  <g class="about-stack">
    <!-- CONCEPT — feature, fix, idea (dashed footprint + lightbulb) -->
    <g class="about-lyr about-lyr--base">
      <path class="about-lyr-base" d="M180 290 L300 338 L180 386 L60 338 Z" />
      <g class="about-icon" transform={`matrix(${ISO} 180 338)`}>
        <circle cx="0" cy="-2.5" r="7" />
        <path d="M-3.5 4.5 L-3 7.5 L3 7.5 L3.5 4.5" />
        <line x1="-2.5" y1="10" x2="2.5" y2="10" />
        <path d="M-2.5 -3 L-1 -0.5 L1 -0.5 L2.5 -3" />
      </g>
    </g>

    <!-- AI — companion and analysis (dashed sheet + sparkle) -->
    <g class="about-lyr about-lyr--ai">
      <path class="about-lyr-side" d="M60 268 L180 316 L180 328 L60 280 Z" />
      <path class="about-lyr-side" d="M180 316 L300 268 L300 280 L180 328 Z" />
      <path class="about-lyr-face" d="M180 220 L300 268 L180 316 L60 268 Z" />
      <g class="about-icon" transform={`matrix(${ISO} 180 268)`}>
        <path d="M0 -12 L2.6 -2.6 L12 0 L2.6 2.6 L0 12 L-2.6 2.6 L-12 0 L-2.6 -2.6 Z" />
      </g>
    </g>

    <!-- DATA — knowledge design (database) -->
    <g class="about-lyr about-lyr--low">
      <path class="about-lyr-side" d="M60 198 L180 246 L180 258 L60 210 Z" />
      <path class="about-lyr-side" d="M180 246 L300 198 L300 210 L180 258 Z" />
      <path class="about-lyr-face" d="M180 150 L300 198 L180 246 L60 198 Z" />
      <g class="about-icon" transform={`matrix(${ISO} 180 198)`}>
        <rect x="-12" y="-9" width="24" height="18" rx="2" />
        <line x1="-12" y1="-3" x2="12" y2="-3" />
        <line x1="-12" y1="3" x2="12" y2="3" />
        <line x1="-4" y1="-9" x2="-4" y2="9" />
      </g>
    </g>

    <!-- API — backend app (server) -->
    <g class="about-lyr about-lyr--mid">
      <path class="about-lyr-side" d="M60 128 L180 176 L180 188 L60 140 Z" />
      <path class="about-lyr-side" d="M180 176 L300 128 L300 140 L180 188 Z" />
      <path class="about-lyr-face" d="M180 80 L300 128 L180 176 L60 128 Z" />
      <g class="about-icon" transform={`matrix(${ISO} 180 128)`}>
        <rect x="-13" y="-9" width="26" height="8" rx="1.8" />
        <rect x="-13" y="1" width="26" height="8" rx="1.8" />
        <circle class="about-icon-dot" cx="-9" cy="-5" r="1.1" />
        <circle class="about-icon-dot" cx="-9" cy="5" r="1.1" />
        <line x1="4" y1="-5" x2="9" y2="-5" />
        <line x1="4" y1="5" x2="9" y2="5" />
      </g>
    </g>

    <!-- UI — web and native app (accent sheet + window, pop glyph) -->
    <g class="about-lyr about-lyr--top">
      <path class="about-lyr-side" d="M60 58 L180 106 L180 118 L60 70 Z" />
      <path class="about-lyr-side" d="M180 106 L300 58 L300 70 L180 118 Z" />
      <path class="about-lyr-face" d="M180 10 L300 58 L180 106 L60 58 Z" />
      <g class="about-icon about-icon--accent" transform={`matrix(${ISO} 180 58)`}>
        <rect x="-13" y="-10" width="26" height="20" rx="2.5" />
        <line x1="-13" y1="-3" x2="13" y2="-3" />
        <circle class="about-icon-dot" cx="-9.5" cy="-6.5" r="1" />
        <circle class="about-icon-dot" cx="-5.5" cy="-6.5" r="1" />
        <circle class="about-icon-dot" cx="-1.5" cy="-6.5" r="1" />
      </g>
    </g>
  </g>

  <!-- Leader lines + captions — the instruction-manual annotation.
       Obtuse-angled elbows alternating side to side (UI starts left). -->
  <g class="about-caps">
    {caps.map((c, i) => {
      const left = i % 2 === 0;
      const nodeX = left ? 60 : 300;
      const bendX = left ? 44 : 316;
      const endX = left ? 12 : 348;
      const textX = left ? 4 : 356;
      const ly = c.y - 14;
      return (
        <g class="about-cap">
          <circle class="about-cap-node" cx={nodeX} cy={c.y} r="1.6" />
          <polyline class="about-cap-line" points={`${nodeX},${c.y} ${bendX},${ly} ${endX},${ly}`} />
          <text class="about-cap-term" x={textX} y={ly - 2} text-anchor={left ? "end" : "start"}>{c.layer.term}</text>
          <text class="about-cap-desc" x={textX} y={ly + 11} text-anchor={left ? "end" : "start"}>{c.layer.desc}</text>
        </g>
      );
    })}
  </g>
</svg>
