---
import SectionHeader from "./SectionHeader.astro";
import { getTranslations } from "../i18n/ui";

const t = getTranslations(Astro.currentLocale).approach;
---

<section id="approach">
  <SectionHeader num="04" label={t.label} title={t.title} />
  <div class="approach-grid">
    {
      t.items.map((item) => (
        <div class="approach-item">
          <div class="approach-num">{item.num}</div>
          <h3 class="approach-title">{item.title}</h3>
          <p class="approach-desc">{item.desc}</p>
        </div>
      ))
    }
  </div>
</section>
