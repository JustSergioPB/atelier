---
import SectionHeader from "./SectionHeader.astro";
import Icon from "./Icon.astro";
import { getRelativeLocaleUrl } from "astro:i18n";
import { getTranslations, resolveLang } from "../i18n/ui";
import { MIDDOT } from "../separators";
import { contact, mailto } from "../contact";
import { shared } from "../i18n/shared";

const lang = resolveLang(Astro.currentLocale);
const t = getTranslations(lang).contact;
const f = getTranslations(lang).footer;
const cookiesHref = getRelativeLocaleUrl(lang, "cookies");
const year = new Date().getFullYear();
---

<footer id="contact">
  <!-- Decorative UML activity diagram — anchored bottom-right, sits behind content -->
  <svg class="contact-uml" viewBox="0 0 660 440" fill="none" aria-hidden="true" focusable="false">
    <!-- initial node -->
    <circle class="uml-init" cx="560" cy="24" r="9" />
    <line class="uml-edge" x1="560" y1="33" x2="560" y2="56" />
    <path class="uml-arrow" d="M560 58 L555 47 L565 47 Z" />

    <!-- action: Specify -->
    <rect class="uml-action" x="500" y="58" width="120" height="40" rx="20" />
    <text class="uml-name" x="560" y="83" text-anchor="middle">Specify</text>
    <line class="uml-edge" x1="560" y1="98" x2="560" y2="120" />
    <path class="uml-arrow" d="M560 122 L555 111 L565 111 Z" />

    <!-- decision -->
    <polygon class="uml-decision" points="560,122 600,148 560,174 520,148" />
    <text class="uml-msg" x="573" y="192" text-anchor="start">[ok]</text>

    <!-- rework branch: decision -> Clarify -> back to Specify -->
    <line class="uml-edge" x1="520" y1="148" x2="442" y2="148" />
    <path class="uml-arrow" d="M440 148 L451 143 L451 153 Z" />
    <text class="uml-msg" x="481" y="140" text-anchor="middle">[vague]</text>
    <rect class="uml-action" x="320" y="128" width="120" height="40" rx="20" />
    <text class="uml-name" x="380" y="153" text-anchor="middle">Clarify</text>
    <line class="uml-edge" x1="380" y1="128" x2="380" y2="78" />
    <line class="uml-edge" x1="380" y1="78" x2="498" y2="78" />
    <path class="uml-arrow" d="M500 78 L489 73 L489 83 Z" />

    <!-- down branch: Build -> Deploy -> final -->
    <line class="uml-edge" x1="560" y1="174" x2="560" y2="198" />
    <path class="uml-arrow" d="M560 200 L555 189 L565 189 Z" />
    <rect class="uml-action" x="500" y="200" width="120" height="40" rx="20" />
    <text class="uml-name" x="560" y="225" text-anchor="middle">Build</text>
    <line class="uml-edge" x1="560" y1="240" x2="560" y2="262" />
    <path class="uml-arrow" d="M560 264 L555 253 L565 253 Z" />
    <rect class="uml-action" x="500" y="264" width="120" height="40" rx="20" />
    <text class="uml-name" x="560" y="289" text-anchor="middle">Deploy</text>
    <line class="uml-edge" x1="560" y1="304" x2="560" y2="328" />
    <path class="uml-arrow" d="M560 330 L555 319 L565 319 Z" />

    <!-- final node -->
    <circle class="uml-final-ring" cx="560" cy="342" r="12" />
    <circle class="uml-final-dot" cx="560" cy="342" r="6" />
  </svg>
  <SectionHeader num="06" label={t.label} title={t.title} />
  <p class="contact-lead">{t.lead}</p>
  <div class="hero-actions">
    <a class="btn btn-primary" href={mailto}>{t.emailCta} <Icon name="arrowRight" /></a>
    <a class="btn btn-ghost" href={contact.linkedin} target="_blank" rel="noopener">{t.linkedinCta}</a>
  </div>
  <div class="contact-bar">
    <div class="contact-bar-meta">
      <span class="contact-bar-text">{t.note} {MIDDOT} {shared.name} {MIDDOT} {f.role}</span>
      <span class="contact-bar-copy">© {year} {shared.name}. {f.rights}</span>
    </div>
    <div class="contact-bar-links">
      <button type="button" class="contact-bar-text contact-bar-btn" data-cookie-settings>{f.cookieSettings}</button>
      <a class="contact-bar-text" href={cookiesHref}>{f.cookies}</a>
      <a class="contact-bar-text" href={contact.linkedin} target="_blank" rel="noopener">{shared.brand.linkedin} <Icon name="arrowUpRight" /></a>
    </div>
  </div>
  <!-- Mobile-only: small UML state machine diagram in the top-left corner -->
  <svg class="contact-sm" viewBox="0 0 440 210" fill="none" aria-hidden="true" focusable="false">
    <!-- initial state -->
    <circle class="uml-init" cx="38" cy="52" r="7" />
    <line class="uml-edge" x1="45" y1="52" x2="76" y2="52" />
    <path class="uml-arrow" d="M78 52 L67 47 L67 57 Z" />

    <!-- state: Idle -->
    <rect class="uml-state" x="78" y="30" width="120" height="44" rx="12" />
    <text class="uml-name" x="138" y="57" text-anchor="middle">Idle</text>

    <!-- Idle -> Active : start() -->
    <line class="uml-edge" x1="198" y1="52" x2="284" y2="52" />
    <path class="uml-arrow" d="M286 52 L275 47 L275 57 Z" />
    <text class="uml-msg" x="242" y="44" text-anchor="middle">start()</text>

    <!-- state: Active -->
    <rect class="uml-state" x="286" y="30" width="130" height="44" rx="12" />
    <text class="uml-name" x="351" y="57" text-anchor="middle">Active</text>

    <!-- Active -> Done : finish() -->
    <line class="uml-edge" x1="351" y1="74" x2="351" y2="138" />
    <path class="uml-arrow" d="M351 140 L346 129 L356 129 Z" />
    <text class="uml-msg" x="362" y="112" text-anchor="start">finish()</text>

    <!-- state: Done -->
    <rect class="uml-state" x="286" y="140" width="130" height="44" rx="12" />
    <text class="uml-name" x="351" y="167" text-anchor="middle">Done</text>

    <!-- Done -> final : reset() -->
    <line class="uml-edge" x1="286" y1="162" x2="170" y2="162" />
    <path class="uml-arrow" d="M168 162 L179 157 L179 167 Z" />
    <text class="uml-msg" x="228" y="154" text-anchor="middle">reset()</text>

    <!-- final state -->
    <circle class="uml-final-ring" cx="150" cy="162" r="12" />
    <circle class="uml-final-dot" cx="150" cy="162" r="6" />
  </svg>
</footer>

<style>
  /* Left column: meta line stacked over the copyright, both left-aligned */
  .contact-bar-meta {
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
  }

  .contact-bar-copy {
    font-family: "Inter", sans-serif;
    font-size: var(--t-caption);
    color: var(--color-text-secondary);
  }

  .contact-bar-links {
    display: flex;
    align-items: center;
    gap: var(--space-m);
    flex-wrap: wrap;
  }

  /* A button styled as a bar link — reopens the cookie banner.
     appearance:none strips the native button look so it inherits the
     .contact-bar-text typography (font, uppercase, letter-spacing) like the links. */
  .contact-bar-btn {
    appearance: none;
    -webkit-appearance: none;
    background: none;
    border: none;
    padding: 0;
    margin: 0;
    line-height: inherit;
    cursor: pointer;
    color: var(--color-pop);
    transition: color 0.15s ease;
  }
  .contact-bar-btn:hover {
    text-decoration: underline;
    text-decoration-thickness: 1px;
    text-underline-offset: 0.25em;
  }
  .contact-bar-btn:focus-visible {
    outline: 2px solid var(--color-pop);
    outline-offset: 2px;
  }
</style>
