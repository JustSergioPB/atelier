---
import Icon from "./Icon.astro";
import { getTranslations } from "../i18n/ui";
import { MIDDOT } from "../separators";
import { contact } from "../contact";
import { shared } from "../i18n/shared";

const t = getTranslations(Astro.currentLocale).footer;
---

<footer class="footer">
  <span class="footer-text">{shared.name} {MIDDOT} {t.role}</span>
  <a class="footer-text" href={contact.linkedin} target="_blank" rel="noopener">{shared.brand.linkedin} <Icon name="arrowUpRight" /></a>
</footer>
