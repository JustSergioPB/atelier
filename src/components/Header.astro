---
import Logo from "./Logo.astro";
import Nav from "./Nav.astro";
import LangSwitcher from "./LangSwitcher.astro";
import ThemeToggle from "./ThemeToggle.astro";
import { getTranslations, resolveLang } from "../i18n/ui";

const lang = resolveLang(Astro.currentLocale);
const t = getTranslations(lang);
const menuLabel = t.header.menu;
const closeLabel = t.header.close;
---

<header class="site-header">
  <Logo />

  <!-- Desktop: inline nav + controls. Hidden below the burger breakpoint. -->
  <nav class="site-nav" aria-label={menuLabel}>
    <Nav variant="bar" />
  </nav>
  <div class="site-controls">
    <LangSwitcher />
    <ThemeToggle />
  </div>

  <!-- Mobile: a single burger that toggles the off-canvas sidebar. -->
  <button
    class="burger"
    type="button"
    aria-label={menuLabel}
    aria-controls="mobile-menu"
    aria-expanded="false"
    data-menu-toggle
  >
    <span class="burger-box"><span class="burger-bar"></span></span>
  </button>
</header>

<!-- Off-canvas sidebar (sm/md only). Closed by default; toggled by the burger. -->
<div class="menu-overlay" data-menu-overlay hidden></div>
<aside id="mobile-menu" class="mobile-menu" aria-label={menuLabel} aria-hidden="true">
  <div class="mobile-menu-head">
    <button class="menu-close" type="button" aria-label={closeLabel} data-menu-close>
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M18 6 6 18M6 6l12 12"></path></svg>
    </button>
  </div>
  <nav class="mobile-menu-nav" aria-label={menuLabel}>
    <Nav variant="panel" id="mobile-nav" />
  </nav>
  <div class="mobile-menu-controls">
    <LangSwitcher />
    <ThemeToggle />
  </div>
</aside>

<script>
  // Publish the sticky header's height as --header-h so the hero can size
  // itself to the remaining viewport. Re-measures on resize and font swap.
  (function () {
    var header = document.querySelector(".site-header") as HTMLElement | null;
    if (!header) return;
    function setHeaderH() {
      document.documentElement.style.setProperty(
        "--header-h",
        header!.offsetHeight + "px"
      );
    }
    setHeaderH();
    if ("ResizeObserver" in window) {
      new ResizeObserver(setHeaderH).observe(header);
    } else {
      window.addEventListener("resize", setHeaderH);
    }
  })();

  // Off-canvas menu: open/close, with the usual escape hatches (overlay click,
  // Escape key, following a nav link). Focus moves into the panel on open and
  // back to the burger on close.
  (function () {
    var toggle = document.querySelector("[data-menu-toggle]") as HTMLButtonElement | null;
    var overlay = document.querySelector("[data-menu-overlay]") as HTMLElement | null;
    var menu = document.getElementById("mobile-menu");
    var closeBtn = document.querySelector("[data-menu-close]") as HTMLButtonElement | null;
    if (!toggle || !overlay || !menu) return;

    function open() {
      document.body.classList.add("menu-open");
      toggle!.setAttribute("aria-expanded", "true");
      menu!.setAttribute("aria-hidden", "false");
      overlay!.hidden = false;
      (menu!.querySelector("a, button") as HTMLElement | null)?.focus();
    }

    function close() {
      document.body.classList.remove("menu-open");
      toggle!.setAttribute("aria-expanded", "false");
      menu!.setAttribute("aria-hidden", "true");
      overlay!.hidden = true;
    }

    function isOpen() {
      return toggle!.getAttribute("aria-expanded") === "true";
    }

    toggle.addEventListener("click", function () {
      isOpen() ? close() : open();
    });
    closeBtn?.addEventListener("click", function () {
      close();
      toggle!.focus();
    });
    overlay.addEventListener("click", close);
    menu.querySelectorAll("[data-nav-link]").forEach(function (link) {
      link.addEventListener("click", close);
    });
    document.addEventListener("keydown", function (e) {
      if (e.key === "Escape" && isOpen()) {
        close();
        toggle!.focus();
      }
    });
  })();

  // Scroll-spy: highlight the nav link of whichever section is at mid-viewport.
  // Marks every matching link (desktop bar + mobile panel) via aria-current.
  (function () {
    var links = Array.prototype.slice.call(
      document.querySelectorAll("[data-nav-link]")
    ) as HTMLAnchorElement[];
    if (!links.length || !("IntersectionObserver" in window)) return;

    var sections = links
      .map(function (l) {
        return document.getElementById((l.getAttribute("href") || "").slice(1));
      })
      .filter(function (s, i, arr): s is HTMLElement {
        return !!s && arr.indexOf(s) === i;
      });
    if (!sections.length) return;

    function setActive(id: string) {
      links.forEach(function (l) {
        if (l.getAttribute("href") === "#" + id) {
          l.setAttribute("aria-current", "true");
        } else {
          l.removeAttribute("aria-current");
        }
      });
    }

    // A thin band at the vertical middle: the section crossing it is "current".
    var io = new IntersectionObserver(
      function (entries) {
        entries.forEach(function (e) {
          if (e.isIntersecting) setActive((e.target as HTMLElement).id);
        });
      },
      { rootMargin: "-50% 0px -50% 0px", threshold: 0 }
    );
    sections.forEach(function (s) { io.observe(s); });
  })();
</script>

<style>
  /* Sticky top bar — replaces the former theme-bar. */
  .site-header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: var(--color-bg);
    border-bottom: 1px solid var(--color-border);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-m);
    padding: 0.75rem var(--space-m);
    transition: background 0.25s ease;
  }

  .site-nav {
    margin-left: auto;
  }

  .site-controls {
    display: flex;
    align-items: center;
    gap: var(--space-xs);
  }

  /* Burger — hidden on desktop, shown below the breakpoint. */
  .burger {
    display: none;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border: 1px solid var(--color-border);
    border-radius: 4px;
    background: var(--color-surface);
    color: var(--color-text-primary);
    cursor: pointer;
    transition: color 0.15s ease, border-color 0.15s ease;
  }

  .burger:hover { border-color: var(--color-pop); }
  .burger:focus-visible { outline: 2px solid var(--color-pop); outline-offset: 2px; }

  .burger-box {
    position: relative;
    display: block;
    width: 18px;
    height: 12px;
  }

  /* Three bars drawn from one element + its pseudo-elements. */
  .burger-bar,
  .burger-bar::before,
  .burger-bar::after {
    position: absolute;
    left: 0;
    width: 100%;
    height: 2px;
    background: currentColor;
    border-radius: 2px;
    transition: transform 0.2s ease, opacity 0.2s ease;
  }

  .burger-bar { top: 50%; transform: translateY(-50%); }
  .burger-bar::before { content: ""; top: -6px; }
  .burger-bar::after { content: ""; top: 6px; }

  /* Burger morphs into an X while the menu is open. */
  :global(body.menu-open) .burger-bar { background: transparent; }
  :global(body.menu-open) .burger-bar::before { top: 0; transform: rotate(45deg); }
  :global(body.menu-open) .burger-bar::after { top: 0; transform: rotate(-45deg); }

  /* Off-canvas sidebar + overlay — only relevant below the breakpoint. */
  .menu-overlay {
    position: fixed;
    inset: 0;
    z-index: 200;
    background: rgba(0, 0, 0, 0.5);
    opacity: 0;
    transition: opacity 0.25s ease;
  }

  :global(body.menu-open) .menu-overlay { opacity: 1; }

  .mobile-menu {
    position: fixed;
    top: 0;
    right: 0;
    z-index: 210;
    display: flex;
    flex-direction: column;
    gap: var(--space-l);
    width: min(80vw, 320px);
    height: 100dvh;
    padding: var(--space-m);
    background: var(--color-surface);
    border-left: 1px solid var(--color-border);
    transform: translateX(100%);
    transition: transform 0.25s cubic-bezier(0.22, 1, 0.36, 1);
    overflow-y: auto;
  }

  :global(body.menu-open) .mobile-menu { transform: translateX(0); }

  .mobile-menu-head {
    display: flex;
    justify-content: flex-end;
  }

  .menu-close {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border: 1px solid var(--color-border);
    border-radius: 4px;
    background: transparent;
    color: var(--color-text-primary);
    cursor: pointer;
    transition: border-color 0.15s ease;
  }

  .menu-close svg { width: 18px; height: 18px; }
  .menu-close:hover { border-color: var(--color-pop); }
  .menu-close:focus-visible { outline: 2px solid var(--color-pop); outline-offset: 2px; }

  .mobile-menu-controls {
    display: flex;
    align-items: center;
    gap: var(--space-xs);
    margin-top: auto;
  }

  /* Respect reduced motion — no slide/fade transitions. */
  @media (prefers-reduced-motion: reduce) {
    .mobile-menu,
    .menu-overlay { transition: none; }
  }

  /* Below 1024px (sm + md): collapse to logo + burger only. */
  @media (max-width: 1023px) {
    .site-nav,
    .site-controls { display: none; }
    .burger { display: inline-flex; }
  }

  /* Desktop: no off-canvas machinery. */
  @media (min-width: 1024px) {
    .menu-overlay,
    .mobile-menu { display: none; }
  }

  @media (max-width: 640px) {
    .site-header { padding: 0.75rem var(--space-s); }
  }
</style>
