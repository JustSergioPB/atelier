---
import { getTranslations } from "../i18n/ui";
import { MIDDOT } from "../separators";
import Icon from "./Icon.astro";
import { contact } from "../contact";
import { shared } from "../i18n/shared";
import HeroTerminal from "./HeroTerminal.astro";

const t = getTranslations(Astro.currentLocale).hero;
---

<section class="hero" id="top">
  <div class="hero-copy">
    <h1 class="hero-title">{t.title}</h1>
    <p class="hero-subtitle">{t.titleSpan}</p>
    <p class="hero-byline"><strong>{shared.name}</strong> {MIDDOT} {t.byline}</p>
    <div class="hero-actions">
      <a class="btn btn-primary" href="#contact">{t.ctaPrimary} <Icon name="arrowRight" /></a>
      <a class="btn btn-ghost" href={contact.linkedin} target="_blank" rel="noopener">{t.ctaSecondary}</a>
    </div>
  </div>
  <HeroTerminal />
</section>
