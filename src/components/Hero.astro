---
import { getTranslations } from "../i18n/ui";
import { MIDDOT, joinMiddot } from "../separators";
import Icon from "./Icon.astro";
import { contact } from "../contact";
import { shared } from "../i18n/shared";

const t = getTranslations(Astro.currentLocale).hero;
---

<section class="hero" id="top">
  <svg class="hero-uml" viewBox="0 0 660 520" fill="none" aria-hidden="true" focusable="false">
    <!-- lifelines (dashed) -->
    <line class="uml-life" x1="90" y1="56" x2="90" y2="500" />
    <line class="uml-life" x1="330" y1="56" x2="330" y2="500" />
    <line class="uml-life" x1="570" y1="56" x2="570" y2="500" />

    <!-- activation bars -->
    <rect class="uml-activation" x="324" y="120" width="12" height="270" />
    <rect class="uml-activation" x="564" y="185" width="12" height="135" />

    <!-- participant boxes -->
    <g class="uml-class">
      <rect x="40" y="20" width="100" height="36" rx="2" />
      <text class="uml-name" x="90" y="43" text-anchor="middle">Client</text>
    </g>
    <g class="uml-class">
      <rect x="270" y="20" width="120" height="36" rx="2" />
      <text class="uml-name" x="330" y="43" text-anchor="middle">Architect</text>
    </g>
    <g class="uml-class">
      <rect x="510" y="20" width="120" height="36" rx="2" />
      <text class="uml-name" x="570" y="43" text-anchor="middle">Deployment</text>
    </g>

    <!-- msg1: Client -> Architect : request() -->
    <line class="uml-edge" x1="90" y1="120" x2="324" y2="120" />
    <path class="uml-arrow" d="M324 120 L313 115 L313 125 Z" />
    <text class="uml-msg" x="207" y="112" text-anchor="middle">request()</text>

    <!-- msg2: Architect -> Deployment : build() -->
    <line class="uml-edge" x1="336" y1="185" x2="564" y2="185" />
    <path class="uml-arrow" d="M564 185 L553 180 L553 190 Z" />
    <text class="uml-msg" x="450" y="177" text-anchor="middle">build()</text>

    <!-- msg3: Deployment --> Architect : bundle (return) -->
    <line class="uml-return" x1="564" y1="250" x2="336" y2="250" />
    <path class="uml-arrow" d="M336 250 L347 245 L347 255 Z" />
    <text class="uml-msg" x="450" y="242" text-anchor="middle">bundle</text>

    <!-- msg4: Architect -> Deployment : release() -->
    <line class="uml-edge" x1="336" y1="315" x2="564" y2="315" />
    <path class="uml-arrow" d="M564 315 L553 310 L553 320 Z" />
    <text class="uml-msg" x="450" y="307" text-anchor="middle">release()</text>

    <!-- msg5: Architect --> Client : live (return) -->
    <line class="uml-return" x1="324" y1="385" x2="102" y2="385" />
    <path class="uml-arrow" d="M102 385 L113 380 L113 390 Z" />
    <text class="uml-msg" x="213" y="377" text-anchor="middle">live</text>
  </svg>
  <p class="hero-eyebrow">{joinMiddot(t.eyebrow)}</p>
  <h1 class="hero-title">
    {t.title.map((seg) => (seg.mark ? <b class="hl">{seg.text}</b> : seg.text))}
    <span>{t.titleSpan}</span>
  </h1>
  <p class="hero-byline"><strong>{shared.name}</strong> {MIDDOT} {t.byline}</p>
  <div class="hero-actions">
    <a class="btn btn-primary" href="#contact">{t.ctaPrimary} <Icon name="arrowRight" /></a>
    <a class="btn btn-ghost" href={contact.linkedin} target="_blank" rel="noopener">{t.ctaSecondary}</a>
  </div>
  <!-- Mobile-only: small UML class diagram in the top-left corner -->
  <svg class="hero-cls" viewBox="0 0 440 300" fill="none" aria-hidden="true" focusable="false">
    <!-- generalization: Button --|> Component -->
    <line class="uml-edge" x1="95" y1="200" x2="95" y2="124" />
    <path class="uml-tri" d="M95 108 L86 124 L104 124 Z" />

    <!-- association: Component -> Theme -->
    <line class="uml-edge" x1="170" y1="66" x2="284" y2="66" />
    <path class="uml-arrow" d="M290 66 L281 61 L281 71 Z" />

    <g class="uml-class">
      <rect x="20" y="24" width="150" height="84" rx="2" />
      <line x1="20" y1="50" x2="170" y2="50" />
      <line x1="20" y1="76" x2="170" y2="76" />
      <text class="uml-name" x="95" y="42" text-anchor="middle">Component</text>
      <text class="uml-attr" x="30" y="67">+ props: Props</text>
      <text class="uml-attr" x="30" y="93">+ render(): UI</text>
    </g>

    <!-- 3rd class, to the right of Component -->
    <g class="uml-class">
      <rect x="290" y="24" width="130" height="84" rx="2" />
      <line x1="290" y1="50" x2="420" y2="50" />
      <line x1="290" y1="76" x2="420" y2="76" />
      <text class="uml-name" x="355" y="42" text-anchor="middle">Theme</text>
      <text class="uml-attr" x="298" y="67">+ mode: Mode</text>
      <text class="uml-attr" x="298" y="93">+ token(): Var</text>
    </g>

    <g class="uml-class">
      <rect x="20" y="200" width="150" height="84" rx="2" />
      <line x1="20" y1="226" x2="170" y2="226" />
      <line x1="20" y1="252" x2="170" y2="252" />
      <text class="uml-name" x="95" y="218" text-anchor="middle">Button</text>
      <text class="uml-attr" x="30" y="243">- variant: Kind</text>
      <text class="uml-attr" x="30" y="269">+ onClick(): void</text>
    </g>
  </svg>
</section>
