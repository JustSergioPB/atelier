---
// Mobile-only UML class diagram (Component / Theme / Button) in the hero's
// top-left corner. Purely presentational; styled via `.hero-cls` in global.css.
---

<svg class="hero-cls" viewBox="0 0 440 300" fill="none" aria-hidden="true" focusable="false">
  <!-- generalization: Button --|> Component -->
  <line class="uml-edge" x1="95" y1="200" x2="95" y2="124" />
  <path class="uml-tri" d="M95 108 L86 124 L104 124 Z" />

  <!-- association: Component -> Theme -->
  <line class="uml-edge" x1="170" y1="66" x2="284" y2="66" />
  <path class="uml-arrow" d="M290 66 L281 61 L281 71 Z" />

  <g class="uml-class">
    <rect x="20" y="24" width="150" height="84" rx="2" />
    <line x1="20" y1="50" x2="170" y2="50" />
    <line x1="20" y1="76" x2="170" y2="76" />
    <text class="uml-name" x="95" y="42" text-anchor="middle">Component</text>
    <text class="uml-attr" x="30" y="67">+ props: Props</text>
    <text class="uml-attr" x="30" y="93">+ render(): UI</text>
  </g>

  <!-- 3rd class, to the right of Component -->
  <g class="uml-class">
    <rect x="290" y="24" width="130" height="84" rx="2" />
    <line x1="290" y1="50" x2="420" y2="50" />
    <line x1="290" y1="76" x2="420" y2="76" />
    <text class="uml-name" x="355" y="42" text-anchor="middle">Theme</text>
    <text class="uml-attr" x="298" y="67">+ mode: Mode</text>
    <text class="uml-attr" x="298" y="93">+ token(): Var</text>
  </g>

  <g class="uml-class">
    <rect x="20" y="200" width="150" height="84" rx="2" />
    <line x1="20" y1="226" x2="170" y2="226" />
    <line x1="20" y1="252" x2="170" y2="252" />
    <text class="uml-name" x="95" y="218" text-anchor="middle">Button</text>
    <text class="uml-attr" x="30" y="243">- variant: Kind</text>
    <text class="uml-attr" x="30" y="269">+ onClick(): void</text>
  </g>
</svg>
