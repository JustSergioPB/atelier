---
// Decorative UML sequence diagram (Client → Architect → Deployment) behind the
// hero. Purely presentational; styled via the `.hero-uml` class in global.css.
---

<svg class="hero-uml" viewBox="0 0 660 520" fill="none" aria-hidden="true" focusable="false">
  <!-- lifelines (dashed) -->
  <line class="uml-life" x1="90" y1="56" x2="90" y2="500" />
  <line class="uml-life" x1="330" y1="56" x2="330" y2="500" />
  <line class="uml-life" x1="570" y1="56" x2="570" y2="500" />

  <!-- activation bars -->
  <rect class="uml-activation" x="324" y="120" width="12" height="270" />
  <rect class="uml-activation" x="564" y="185" width="12" height="135" />

  <!-- participant boxes -->
  <g class="uml-class">
    <rect x="40" y="20" width="100" height="36" rx="2" />
    <text class="uml-name" x="90" y="43" text-anchor="middle">Client</text>
  </g>
  <g class="uml-class">
    <rect x="270" y="20" width="120" height="36" rx="2" />
    <text class="uml-name" x="330" y="43" text-anchor="middle">Architect</text>
  </g>
  <g class="uml-class">
    <rect x="510" y="20" width="120" height="36" rx="2" />
    <text class="uml-name" x="570" y="43" text-anchor="middle">Deployment</text>
  </g>

  <!-- msg1: Client -> Architect : request() -->
  <line class="uml-edge" x1="90" y1="120" x2="324" y2="120" />
  <path class="uml-arrow" d="M324 120 L313 115 L313 125 Z" />
  <text class="uml-msg" x="207" y="112" text-anchor="middle">request()</text>

  <!-- msg2: Architect -> Deployment : build() -->
  <line class="uml-edge" x1="336" y1="185" x2="564" y2="185" />
  <path class="uml-arrow" d="M564 185 L553 180 L553 190 Z" />
  <text class="uml-msg" x="450" y="177" text-anchor="middle">build()</text>

  <!-- msg3: Deployment --> Architect : bundle (return) -->
  <line class="uml-return" x1="564" y1="250" x2="336" y2="250" />
  <path class="uml-arrow" d="M336 250 L347 245 L347 255 Z" />
  <text class="uml-msg" x="450" y="242" text-anchor="middle">bundle</text>

  <!-- msg4: Architect -> Deployment : release() -->
  <line class="uml-edge" x1="336" y1="315" x2="564" y2="315" />
  <path class="uml-arrow" d="M564 315 L553 310 L553 320 Z" />
  <text class="uml-msg" x="450" y="307" text-anchor="middle">release()</text>

  <!-- msg5: Architect --> Client : live (return) -->
  <line class="uml-return" x1="324" y1="385" x2="102" y2="385" />
  <path class="uml-arrow" d="M102 385 L113 380 L113 390 Z" />
  <text class="uml-msg" x="213" y="377" text-anchor="middle">live</text>
</svg>
