---
import { getRelativeLocaleUrl } from "astro:i18n";
import { languages, getTranslations, resolveLang } from "../i18n/ui";

const current = resolveLang(Astro.currentLocale);
const label = getTranslations(current).themeBar.langLabel;
const locales = Object.keys(languages) as Array<keyof typeof languages>;

// Keep the visitor on the same page when switching language: strip the current
// locale prefix off the path and re-prefix it for each target locale.
const prefixes: Record<keyof typeof languages, string> = { es: "", en: "/en" };
const currentPrefix = prefixes[current];
const pathname = Astro.url.pathname;
const rest =
  currentPrefix && (pathname === currentPrefix || pathname.startsWith(currentPrefix + "/"))
    ? pathname.slice(currentPrefix.length)
    : pathname;
const slug = rest.replace(/^\/+/, "").replace(/\/+$/, "");
---

<div class="lang-switcher" role="group" aria-label={label}>
  {
    locales.map((locale) => (
      <a
        class="lang-opt"
        href={getRelativeLocaleUrl(locale, slug)}
        hreflang={locale}
        aria-current={locale === current ? "true" : undefined}
      >
        {languages[locale]}
      </a>
    ))
  }
</div>

<style>
  .lang-switcher {
    display: inline-flex;
    align-items: center;
    gap: 2px;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 4px;
    padding: 2px;
    /* Sits on a solid ledge like the CTA buttons — the control is a physical
       object resting on the page. */
    box-shadow: 0 4px 0 0 var(--color-border), 0 6px 10px rgba(0, 0, 0, 0.16);
  }

  .lang-opt {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    height: 24px;
    padding: 0 8px;
    border-radius: 3px;
    font-family: "Space Grotesk", sans-serif;
    font-size: var(--t-label);
    font-weight: 600;
    letter-spacing: 0.12em;
    text-decoration: none;
    color: var(--color-text-tertiary);
    transition: background 0.15s ease, color 0.15s ease, transform 0.08s ease;
  }

  .lang-opt:hover { color: var(--color-text-secondary); }

  /* Press: the segment dips toward the ledge. */
  .lang-opt:active { transform: translateY(2px); }

  .lang-opt[aria-current="true"] {
    background: var(--color-surface-raised);
    color: var(--color-text-primary);
    /* Selected segment reads as pushed in — recessed into the control. */
    box-shadow: inset 0 2px 4px rgba(0, 0, 0, 0.28);
  }

  .lang-opt:focus-visible { outline: 2px solid var(--color-pop); outline-offset: 2px; }

  @media (prefers-reduced-motion: reduce) {
    .lang-opt:active { transform: none; }
  }
</style>
