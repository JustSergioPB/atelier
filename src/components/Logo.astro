---
import { getRelativeLocaleUrl } from "astro:i18n";
import { resolveLang } from "../i18n/ui";
import { shared } from "../i18n/shared";

// Brand mark as theme-specific PNGs (generated by scripts/gen-logo.mjs). Both
// ship in the markup; CSS shows the one matching the active [data-theme], which
// is set before paint in BaseLayout, so there's no swap flash.
const lang = resolveLang(Astro.currentLocale);
const home = getRelativeLocaleUrl(lang, "");
---

<a class="logo" href={home} aria-label={shared.name}>
  <img class="logo-img logo-img--light" src="/logo-light.png" alt={shared.name} width="28" height="28" />
  <img class="logo-img logo-img--dark" src="/logo-dark.png" alt={shared.name} width="28" height="28" />
</a>

<style>
  .logo {
    display: inline-flex;
    align-items: center;
    text-decoration: none;
  }

  .logo-img {
    display: block;
    height: 28px;
    width: auto;
  }

  /* Light theme shows the dark mark; dark theme shows the light mark. */
  .logo-img--dark { display: none; }
  :global([data-theme="dark"]) .logo-img--light { display: none; }
  :global([data-theme="dark"]) .logo-img--dark { display: block; }

  .logo:hover { opacity: 0.7; }
  .logo:focus-visible { outline: 2px solid var(--color-pop); outline-offset: 4px; }
</style>
