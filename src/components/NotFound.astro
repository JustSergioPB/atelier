---
import { getRelativeLocaleUrl } from "astro:i18n";
import { getTranslations, resolveLang } from "../i18n/ui";

const lang = resolveLang(Astro.currentLocale);
const t = getTranslations(lang).notFound;
const homeHref = getRelativeLocaleUrl(lang);
---

<article class="notfound">
  <p class="section-label">{t.label}</p>
  <h1 class="notfound-title">
    {t.title.map((seg) => ("mark" in seg && seg.mark ? <span class="hl">{seg.text}</span> : seg.text))}
  </h1>
  <p class="notfound-lead">{t.lead}</p>
  <a class="notfound-home" href={homeHref}>← {t.home}</a>
</article>

<style>
  .notfound {
    max-width: 640px;
    padding: var(--space-xl) 0;
  }

  .notfound-title {
    font-family: "Space Grotesk", sans-serif;
    font-size: var(--t-headline);
    font-weight: 700;
    letter-spacing: -0.035em;
    line-height: 1;
    color: var(--color-text-primary);
    margin: var(--space-xs) 0 var(--space-m);
  }

  .notfound-title .hl {
    color: var(--color-pop);
  }

  .notfound-lead {
    font-family: "Space Grotesk", sans-serif;
    font-size: clamp(1.15rem, 2vw, 1.4rem);
    font-weight: 400;
    line-height: 1.45;
    letter-spacing: -0.01em;
    color: var(--color-text-tertiary);
    margin-bottom: var(--space-l);
  }

  .notfound-home {
    display: inline-block;
    font-family: "Space Grotesk", sans-serif;
    font-size: var(--t-label);
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-pop);
    text-decoration: none;
    transition: color 0.15s ease;
  }

  .notfound-home:hover {
    text-decoration: underline;
    text-decoration-thickness: 1px;
    text-underline-offset: 0.25em;
  }

  .notfound-home:focus-visible {
    outline: 2px solid var(--color-pop);
    outline-offset: 2px;
  }
</style>
