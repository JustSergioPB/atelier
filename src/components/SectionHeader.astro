---
interface Props {
  // Accepted for backward-compatibility with callers; no longer rendered.
  num?: string;
  label?: string;
  title: string;
  subtitle?: string;
  center?: boolean;
}

const { label, title, subtitle, center } = Astro.props;
---

<div class:list={["section-header", { "is-centered": center }]}>
  <div class="section-header-content">
    {label && <p class="section-label">{label}</p>}
    <h2 class="section-title">{title}</h2>
    {subtitle && <p class="section-subtitle">{subtitle}</p>}
  </div>
</div>
