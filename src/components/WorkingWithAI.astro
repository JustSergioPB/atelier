---
import SectionHeader from "./SectionHeader.astro";
import { getTranslations } from "../i18n/ui";

const t = getTranslations(Astro.currentLocale).ai;
---

<section id="ai">
  <SectionHeader num="05" label={t.label} title={t.title} />
  <p class="ai-lead">
    {t.lead.map((seg) => (seg.mark ? <span class="accent">{seg.text}</span> : seg.text))}
  </p>
  {
    t.items.map((item) => (
      <div class="ai-item">
        <div class="ai-term">{item.term}</div>
        <p class="ai-desc">{item.desc}</p>
      </div>
    ))
  }
</section>
