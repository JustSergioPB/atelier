---
import ThemeToggle from "../components/ThemeToggle.astro";
import LangSwitcher from "../components/LangSwitcher.astro";
import CookieBanner from "../components/CookieBanner.astro";
import { getTranslations, htmlLang, resolveLang } from "../i18n/ui";
import { MIDDOT } from "../separators";
import { shared } from "../i18n/shared";
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const lang = resolveLang(Astro.currentLocale);
const t = getTranslations(lang);

const {
  title = t.meta.title,
  description = t.meta.description,
} = Astro.props;
---

<!DOCTYPE html>
<html lang={htmlLang[lang]} data-theme="light">
  <head>
    <meta charset="UTF-8" />
    <script is:inline>
      // Runs before paint to set the theme — prevents a flash of the wrong theme.
      (function () {
        try {
          var mode = localStorage.getItem("theme") || "light";
          var dark =
            mode === "dark" ||
            (mode === "system" && matchMedia("(prefers-color-scheme: dark)").matches);
          document.documentElement.setAttribute("data-theme", dark ? "dark" : "light");
        } catch (e) {}
      })();
    </script>
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&family=Inter:wght@300;400;500&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <header class="theme-bar">
      <span class="theme-bar-label">{shared.name} {MIDDOT} <strong>{t.themeBar.location}</strong></span>
      <div class="theme-bar-controls">
        <LangSwitcher />
        <ThemeToggle />
      </div>
    </header>

    <main class="page">
      <slot />
    </main>

    <CookieBanner />

    <script>
      // Motion as progressive enhancement — content is fully visible without this.
      (function () {
        var reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
        if (reduce || !("IntersectionObserver" in window)) return;

        document.documentElement.classList.add("motion");

        function reveal(entries: IntersectionObserverEntry[], obs: IntersectionObserver) {
          entries.forEach(function (e) {
            if (e.isIntersecting) {
              e.target.classList.add("is-visible");
              obs.unobserve(e.target);
            }
          });
        }

        // Content blocks fade up as they enter the viewport.
        var contentIO = new IntersectionObserver(reveal, {
          threshold: 0.12,
          rootMargin: "0px 0px -8% 0px",
        });
        var selector =
          ".section-header, .about-lead, .about-body, .exp-item," +
          " .approach-item, .ai-lead, .ai-item, .contact-lead, .contact-sub," +
          " #contact .hero-actions, .contact-note, .footer";
        document.querySelectorAll(selector).forEach(function (el: Element) {
          el.classList.add("reveal");
          contentIO.observe(el);
        });

        // Section rules draw in.
        var ruleIO = new IntersectionObserver(reveal, {
          threshold: 0,
          rootMargin: "0px 0px -10% 0px",
        });
        document.querySelectorAll("section").forEach(function (el: Element) {
          ruleIO.observe(el);
        });

        // Hero: orchestrated entrance on load.
        var hero = document.querySelector(".hero");
        if (hero) {
          var kids = Array.prototype.slice.call(hero.children) as Element[];
          kids.forEach(function (el: Element) { el.classList.add("reveal"); });
          requestAnimationFrame(function () {
            requestAnimationFrame(function () {
              kids.forEach(function (el: Element) { el.classList.add("is-visible"); });
            });
          });
        }
      })();
    </script>
  </body>
</html>
